# Git Commit Tool - Environment Configuration

# Application Name (optional)
GITHUB_APP_NAME=Git Commit Tool

# Node Environment
NODE_ENV=development

# Port (default is 3000 for Next.js)
PORT=3000

# GitHub API Rate Limit Notes:
# - Authenticated requests: 5,000 requests/hour
# - Unauthenticated requests: 60 requests/hour
# - This tool uses throttling (500ms between commits) to avoid rate limits

# Security Notes:
# - Never commit actual tokens to version control
# - Tokens are handled in memory only, never stored in database
# - All tokens are validated before use
